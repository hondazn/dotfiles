layout {
    pane size=1 borderless=true {
        plugin location="tab-bar"
    }
    pane split_direction="vertical" {
        pane size="30%" command="fish" {
            args "-ic" "lazygit -ucf (lazygit -cd)/config.yml,(lazygit -cd)/agent-coding.yml"
        }
        pane split_direction="horizontal" {
            pane command="fish" focus=true {
                args "-ic" "claude"
            }
            pane size="25%" command="fish"
        }
    }
    pane size=1 borderless=true {
        plugin location="status-bar"
    }

    swap_tiled_layout name="lazygit" {
        tab {
            pane size=1 borderless=true
            pane split_direction="vertical" {
                pane size="60%" focus=true
                pane split_direction="horizontal" {
                    pane
                    pane size="20%"
                }
            }
            pane size=1 borderless=true
        }
    }
}
